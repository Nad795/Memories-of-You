  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 5_Q6_Minggu
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Malam minggu tiba. Dulu kamu cemas kalau tidak ada dia. Sekarang
    kamu sendirian di kamar.

'
  choices:
  - choiceText: Waktunya Me Time! Aku bisa maskeran, nonton drakor, atau main game
      sepuasnya tanpa gangguan. Seru banget!
    systemResponse: Kamu menemukan kebebasan yang selama ini terkekang.
    addDistress: -10
    addDenial: 0
    addRumination: 0
    addHope: 20
    category: 0
  - choiceText: 'Aku merasa tenang. Ternyata kesendirian itu beda dengan kesepian.
      Aku nyaman dengan diriku sendiri.

'
    systemResponse: Kamu sudah berdamai dengan isi kepalamu sendiri.
    addDistress: -10
    addDenial: 0
    addRumination: -15
    addHope: 0
    category: 0
  - choiceText: 'Aku pakai waktu ini buat ngerjain hobi/tugas. Lebih faedah daripada
      galau nggak jelas.

'
    systemResponse: Energi yang dulu habis untuk rindu, kini kamu pakai untuk maju.
    addDistress: 0
    addDenial: 0
    addRumination: -10
    addHope: 15
    category: 0
