  m_Name: 3_Q5_Notif
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Ada notif pesan dari temanmu yang berkata bahwa dia melihat si ***
    di cafe alka.

'
  choices:
  - choiceText: 'Aku akan kebetulan ingin ke cafe itu sekarang. Siapa tahu kami bertemu
      dan bisa ngobrol santai.

'
    systemResponse: Kamu merancang 'kebetulan' karena takdir tidak lagi mempertemukan
      kalian.
    addDistress: 10
    addDenial: 0
    addRumination: 0
    addHope: 25
    category: 6
  - choiceText: 'Aku titip salam saja, biar dia tahu aku masih eksis.

'
    systemResponse: Kamu melambai dari kejauhan, berharap dia menoleh.
    addDistress: 0
    addDenial: 0
    addRumination: 10
    addHope: 5
    category: 0
  - choiceText: 'Jangan ke sana. Itu cuma akan bikin canggung dan merusak hariku.

'
    systemResponse: Kamu menahan kakimu demi menjaga kewarasanmu.
    addDistress: 5
    addDenial: 0
    addRumination: -5
    addHope: 0
    category: 0
