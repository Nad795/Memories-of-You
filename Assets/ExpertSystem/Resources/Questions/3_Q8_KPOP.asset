  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 3_Q8_KPOP
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Kamu teringat dia pernah mengeluh soal hobimu yang sangat senang
    dengan idol KPOP yang sangat menyita waktu. Pikiranmu mulai berandai-andai.

'
  choices:
  - choiceText: 'Kalau aku berhenti total dari hobiku sekarang, apakah dia akan kembali
      bersahabat denganku?

'
    systemResponse: Kamu bersedia membunuh bagian dari dirimu sendiri demi menghidupkan
      hubungan ini.
    addDistress: 25
    addDenial: 0
    addRumination: 0
    addHope: 20
    category: 0
  - choiceText: 'Mungkin aku bisa mengurangi hobiku drastis demi dia, asalkan dia
      jangan pergi.

'
    systemResponse: 'Kamu mulai menawar: ''Berapa banyak dari diriku yang harus kubayar?'
    addDistress: 0
    addDenial: 0
    addRumination: 15
    addHope: 10
    category: 0
  - choiceText: 'Hobiku adalah bagian dari diriku. Kalau dia tidak bisa terima, berarti
      memang tidak cocok.

'
    systemResponse: Kamu menyadari bahwa cinta seharusnya tidak memintamu menjadi
      orang lain.
    addDistress: 5
    addDenial: 0
    addRumination: 0
    addHope: -15
    category: 0
