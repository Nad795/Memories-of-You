  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 1_Q7_Gitar
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: Gitar kesayanganmu berdebu di sudut kamar. Padahal biasanya dia yang
    selalu memainkan gitar itu.
  choices:
  - choiceText: Lebih baik kubersihkan saja. Siapa tahu nanti dia datang dan mau
      memainkannya lagi.
    systemResponse: Kamu menyiapkan panggung untuk musisi yang sudah meninggalkan
      gedung.
    addDistress: 0
    addDenial: 15
    addRumination: 0
    addHope: 10
    category: 0
  - choiceText: 'Biarin aja di situ. Itu cuma benda mati, nggak ada hubungannya sama
      perasaan.

'
    systemResponse: Kamu pura-pura tidak peduli, tapi matamu terus melirik ke sudut
      itu.
    addDistress: 0
    addDenial: 10
    addRumination: 5
    addHope: 0
    category: 0
  - choiceText: Aku harus memindahkannya ke gudang dan menutupnya dengan kain. Melihatnya
      membuat dadaku sesak.
    systemResponse: Menyingkirkan benda itu tidak menyingkirkan kenangannya.
    addDistress: 10
    addDenial: -5
    addRumination: 0
    addHope: 0
    category: 0
