  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 4_Q9_Liburan
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: HP-mu bergetar terus. Grup chat teman-temanmu sedang ramai membahas
    rencana liburan ke Batu yang sudah sebulan lalu kalian membicarakannya. Notifikasi
    itu terasa mengganggu.
  choices:
  - choiceText: Aku mute notifikasinya atau matikan HP. Berisik. Aku nggak punya
      energi buat pura-pura excited.
    systemResponse: Dunia luar terasa terlalu terang dan bising untuk matamu yang
      lelah.
    addDistress: 10
    addDenial: 10
    addRumination: 0
    addHope: 0
    category: 9
  - choiceText: 'Aku baca sekilas, lalu arsipkan chat-nya. Aku senang mereka happy,
      tapi aku belum siap ikut. Dan itu nggak apa-apa.

'
    systemResponse: 'Kamu membuat batasan yang sehat. Kamu tidak memaksakan diri
      untuk tampil sosial

'
    addDistress: -5
    addDenial: 0
    addRumination: -10
    addHope: 0
    category: 11
  - choiceText: 'Aku merasa bersalah karena nggak ikut nimbrung, tapi jariku terasa
      berat banget buat ngetik.

'
    systemResponse: Rasa bersalah adalah teman setia yang selalu menemanimu dalam
      diam.
    addDistress: 0
    addDenial: 0
    addRumination: 15
    addHope: -5
    category: 0
