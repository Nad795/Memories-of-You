  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 4_Q1_Kasur
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Kasurmu terasa seperti magnet raksasa. Kamu sudah bangun 2 jam lalu,
    tapi badanmu menolak bergerak. Rasanya terlalu berat untuk menghadapi dunia hari
    ini.

'
  choices:
  - choiceText: 'Aku akan tarik selimut lagi dan tidur sampai sore. Tidur adalah
      satu-satunya cara aku bisa kabur dari kenyataan.

'
    systemResponse: Dunia mimpi lebih ramah daripada dunia nyata yang menunggumu
      di luar selimut.
    addDistress: 5
    addDenial: 15
    addRumination: 0
    addHope: 0
    category: 9
  - choiceText: 'Aku hanya bengong menatap langit-langit kamar. Otakku kosong, badanku
      lemas.

'
    systemResponse: Waktu berjalan, tapi kamu membeku di satu titik yang menyakitkan.
    addDistress: 15
    addDenial: 0
    addRumination: -5
    addHope: 0
    category: 0
  - choiceText: 'Aku memaksakan diri bangun cuma untuk minum atau ke kamar mandi,
      lalu kembali meringkuk.

'
    systemResponse: Kamu bertahan hidup dalam mode paling rendah, seperti lampu darurat
      yang redup.
    addDistress: 10
    addDenial: 0
    addRumination: 0
    addHope: 0
    category: 0
