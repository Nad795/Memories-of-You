  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 3_Q1_Respon
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Apa mungkin dia tidak merespon pesanmu karena isinya kurang jelas?

'
  choices:
  - choiceText: 'Bisa jadi dia memilih untuk diam karena bingung bagaimana harus
      menanggapinya tanpa memperbesar konflik. Dia butuh waktu, bukan pergi.

'
    systemResponse: Kamu menciptakan alasan yang nyaman agar penolakan ini tidak
      terasa nyata.
    addDistress: 0
    addDenial: 5
    addRumination: 0
    addHope: 15
    category: 0
  - choiceText: Sepertinya aku yang salah bicara. Harusnya aku nggak mendesak dia.
      Aku terlalu agresif.
    systemResponse: Kamu menyalahkan dirimu sendiri demi membebaskan dia dari rasa
      bersalah.
    addDistress: 10
    addDenial: 0
    addRumination: 20
    addHope: 0
    category: 0
  - choiceText: 'Sepertinya dia memang sudah tidak peduli lagi. Tidak ada respon
      adalah respon.

'
    systemResponse: Kesunyian itu adalah jawaban paling keras yang pernah kamu dengar.
    addDistress: 15
    addDenial: 0
    addRumination: 0
    addHope: -10
    category: 0
