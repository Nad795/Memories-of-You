  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 5_Q7_Jin
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Jika ada jin yang bisa mengabulkan satu permintaan: "Kembali ke
    masa lalu bersamanya" atau "Masa depan misterius tanpanya", kamu pilih mana?

'
  choices:
  - choiceText: Masa depan misterius! Aku penasaran petualangan seru apa yang menantiku
      di depan sana.
    systemResponse: Matamu kini menatap ke depan, tempat di mana harapan berada.
    addDistress: 0
    addDenial: 0
    addRumination: 0
    addHope: 25
    category: 0
  - choiceText: 'Masa lalu biarlah berlalu. Aku tidak mau mengulang buku yang sama
      dua kali. Ending-nya bakal sama.

'
    systemResponse: Kamu menutup buku lama itu dengan tegas. Pelajarannya sudah kamu
      ambil.
    addDistress: 0
    addDenial: -10
    addRumination: -20
    addHope: 0
    category: 0
  - choiceText: Aku memilih hari ini. Aku bersyukur dengan keadaanku sekarang, tanpa
      dia aku nggak akan sekuat ini.
    systemResponse: Kamu menemukan kedamaian di detik ini. Itu adalah hadiah terbesar.
    addDistress: -15
    addDenial: 0
    addRumination: 0
    addHope: 15
    category: 0
