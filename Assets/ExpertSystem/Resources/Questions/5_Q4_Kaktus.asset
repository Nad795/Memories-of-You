  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 5_Q4_Kaktus
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Jika "kaktus" itu mulai bertunas lagi, apakah kamu siap untuk merawatnya
    untuk dirimu sendiri dan bukan untuk mengenangnya?

'
  choices:
  - choiceText: 'Iya, tunas itu adalah simbol awal baru. Aku siap merawatnya untuk
      kebahagiaanku sendiri.

'
    systemResponse: Tunas itu kecil, tapi akarnya kuat karena pernah ditempa badai.
    addDistress: 0
    addDenial: 0
    addRumination: 0
    addHope: 20
    category: 0
  - choiceText: 'Aku akan merawatnya sebagai pengingat bahwa aku pernah hancur, tapi
      aku tumbuh kembali.

'
    systemResponse: Bekas lukamu bukan aib, itu adalah medali kemenanganmu.
    addDistress: -10
    addDenial: 0
    addRumination: -10
    addHope: 0
    category: 0
  - choiceText: 'Aku siap. Sekarang aku merawatnya karena aku mencintai diriku, bukan
      karena ingin dipuji orang lain.

'
    systemResponse: Kamu akhirnya jatuh cinta pada orang yang tepat yaitu dirimu
      sendiri.
    addDistress: 0
    addDenial: -10
    addRumination: 0
    addHope: 15
    category: 0
