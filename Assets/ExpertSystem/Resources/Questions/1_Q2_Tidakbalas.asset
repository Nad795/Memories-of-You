  m_Name: 1_Q2_Tidakbalas
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: "Dia sudah tidak membalas pesanmu sejak kemarin sore\u2026\r\n"
  choices:
  - choiceText: Pasti HP dia rusak, nanti juga dia balas dan telepon aku.
    systemResponse: Kamu menatap layar HP yang gelap, menunggu notif yang tak kunjung
      datang.
    addDistress: -5
    addDenial: 15
    addRumination: 0
    addHope: 15
    category: 0
  - choiceText: Dia pasti buka HP untuk membalas chat yang sangat penting dahulu.
    systemResponse: Kamu menciptakan skenario paling masuk akal agar dadamu tidak
      sesak.
    addDistress: 5
    addDenial: 5
    addRumination: 10
    addHope: 0
    category: 0
  - choiceText: 'Dia sedang online tapi tidak membalasku. Ini sengaja.

'
    systemResponse: Status online itu menyala terang, membakar sedikit harapanmu.
    addDistress: 20
    addDenial: -20
    addRumination: 0
    addHope: -20
    category: 0
