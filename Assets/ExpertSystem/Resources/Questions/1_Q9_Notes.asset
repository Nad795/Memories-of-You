  m_Name: 1_Q9_Notes
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Kamu memposting di notes instogram kalau kamu sedang sedih dengan
    lagu yang galau. Seseorang berkomentar: ''Kamu kenapa? Cerita sini! Kamu jangan
    sedih lama-lama ya, kamu kuat!'' Jari-jarimu gemetar di atas keyboard. Apa balasanmu?'
  choices:
  - choiceText: 'Haha iya dong! Ini cuma lagi suka lagunya aja kok, aslinya aku happy!

'
    systemResponse: Kamu mengetik 'Haha' dengan wajah datar tanpa ekspresi.
    addDistress: 0
    addDenial: 15
    addRumination: 0
    addHope: 5
    category: 0
  - choiceText: 'Makasih ya support-nya.

'
    systemResponse: Jawaban diplomatis. Cara termudah untuk mengakhiri percakapan
      yang tidak nyaman.
    addDistress: 0
    addDenial: 5
    addRumination: 5
    addHope: 0
    category: 0
  - choiceText: Jujur masih berat banget, tapi makasih ya sudah menyemangati.
    systemResponse: Mengakui luka sedikit saja membuat pertahananmu nyaris runtuh.
    addDistress: 10
    addDenial: -10
    addRumination: 0
    addHope: 0
    category: 0
