  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 1_Q1_Mengapa
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Mengapa sikap dia akhir-akhir ini terlihat berbeda?

'
  choices:
  - choiceText: Sepertinya dia memang sedang sibuk, aku harus sabar menunggunya.
      Nanti kalau energinya balik, dia bakal seperti biasa lagi.
    systemResponse: Kamu meyakinkan dirimu sendiri. Kesabaran adalah bentuk cintamu,
      ya?
    addDistress: -5
    addDenial: 10
    addRumination: 0
    addHope: 10
    category: 1
  - choiceText: Sepertinya dia sedang ada masalah yang tidak kuketahui, semoga dia
      baik-baik saja. Manusia butuh ruang.
    systemResponse: '"Kamu mencoba memahaminya secara dewasa, meski hatimu sendiri
      penuh tanda tanya.'
    addDistress: 0
    addDenial: 5
    addRumination: 15
    addHope: 0
    category: 0
  - choiceText: Sepertinya dia tidak nyaman dengan kehadiranku, seperti sedang menjaga
      jarak.
    systemResponse: Instingmu berteriak ada yang salah.
    addDistress: 15
    addDenial: -10
    addRumination: 0
    addHope: -10
    category: 0
