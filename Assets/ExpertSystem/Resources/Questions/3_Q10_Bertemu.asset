  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 3_Q10_Bertemu
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: Kamu berpikir untuk mengajak dia bertemu satu kali lagi dengan alasan
    mencari penjelasan terakhir.
  choices:
  - choiceText: 'Itu cuma alasanku saja. Aslinya aku berharap saat bertemu, aku bisa
      memeluknya dan dia luluh lagi.

'
    systemResponse: Kamu merancang jebakan untuk hatimu sendiri, berharap keajaiban
      terjadi di menit terakhir.
    addDistress: 0
    addDenial: 15
    addRumination: 0
    addHope: 25
    category: 0
  - choiceText: 'Aku butuh pertemuan ini untuk memastikan apakah benar-benar tidak
      ada harapan lagi.

'
    systemResponse: Kamu mencari paku terakhir untuk peti mati hubungan ini.
    addDistress: 10
    addDenial: 0
    addRumination: 20
    addHope: 0
    category: 0
  - choiceText: Penjelasan apa lagi? Diamnya dia sudah cukup menjelaskan semuanya.
    systemResponse: Kesunyian adalah penjelasan paling jujur yang pernah dia berikan.
    addDistress: 15
    addDenial: 0
    addRumination: 0
    addHope: -15
    category: 0
