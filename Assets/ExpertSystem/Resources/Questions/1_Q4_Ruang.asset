  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 1_Q4_Ruang
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: Jika kamu memberikannya ruang, apakah menurutmu hubungan kalian akan
    membaik dengan sendirinya?
  choices:
  - choiceText: Iya, aku hanya perlu bertahan dan sabar menunggu.
    systemResponse: Harapan adalah obat bius yang paling kuat saat ini.
    addDistress: 0
    addDenial: 10
    addRumination: 0
    addHope: 20
    category: 0
  - choiceText: 'Aku tidak yakin, dia tidak pernah seperti ini sebelumnya.

'
    systemResponse: Kamu menutupi fakta bahwa kamu sedang ditinggalkan.
    addDistress: 10
    addDenial: 0
    addRumination: 10
    addHope: 0
    category: 0
  - choiceText: Aku kuatir kami akan semakin menjauh
    systemResponse: Ketakutan itu dingin, merambat naik dari ujung kakimu.
    addDistress: 15
    addDenial: 0
    addRumination: 0
    addHope: -10
    category: 0
