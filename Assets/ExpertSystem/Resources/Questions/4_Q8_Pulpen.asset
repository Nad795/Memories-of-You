  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 4_Q8_Pulpen
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Kamu tidak sengaja menjatuhkan pulpen ke lantai kamarmu. Kamu menatap
    benda itu tergeletak di sana.

'
  choices:
  - choiceText: 'Aku biarkan saja di situ. Membungkuk untuk mengambilnya rasanya
      butuh tenaga yang tidak aku punya.

'
    systemResponse: Benda itu akan tetap di sana berhari-hari, menjadi monumen kecil
      dari kelelahanmu.
    addDistress: 10
    addDenial: 5
    addRumination: 0
    addHope: 0
    category: 0
  - choiceText: 'Aku menendangnya ke kolong meja. Biar hilang sekalian, sama seperti
      semangatku.

'
    systemResponse: Amarah kecil itu meletup, tapi langsung padam digantikan rasa
      lelah.
    addDistress: 5
    addDenial: 0
    addRumination: 10
    addHope: 0
    category: 0
  - choiceText: 'Aku menatapnya lama sekali, lalu tiba-tiba menangis cuma gara-gara
      pulpen jatuh. Aku serapah itu.

'
    systemResponse: Bukan pulpennya yang membuatmu menangis, tapi retakan di hatimu
      yang akhirnya pecah.
    addDistress: 20
    addDenial: 0
    addRumination: 0
    addHope: 0
    category: 0
