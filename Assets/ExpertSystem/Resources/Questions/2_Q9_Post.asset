  m_Name: 2_Q9_Post
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: 'Baru beberapa minggu kalian tidak bicara, dia sudah memposting 
    story di 2nd accountnya pergi ke Bali dengan teman barunya. Posisimu digantikan
    begitu cepat.

'
  choices:
  - choiceText: "\u201COh, jadi selama ini aku cuma ban serep? Baguslah.\u201D\r\n"
    systemResponse: Rasa tidak berharga itu menyusup masuk, membuatmu meragukan kualitas
      dirimu.
    addDistress: 15
    addDenial: 0
    addRumination: 10
    addHope: 0
    category: 5
  - choiceText: '"Dasar murahan. Gampang banget dia nempel sama orang lain dan langsung
      dia jadiin sahabat baru. Ternyata dia emang nggak punya hati."

'
    systemResponse: Kamu menyerang karakternya karena egomu terluka parah.
    addDistress: 20
    addDenial: 0
    addRumination: 15
    addHope: 0
    category: 3
  - choiceText: 'Langsung memblokir akunnya saat itu juga. "Aku nggak sudi lihat
      muka pengkhianat itu lagi."

'
    systemResponse: ' Blokir adalah satu-satunya kendali yang kamu miliki saat ini.'
    addDistress: -5
    addDenial: 0
    addRumination: 10
    addHope: 0
    category: 0
