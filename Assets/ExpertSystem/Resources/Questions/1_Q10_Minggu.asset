  m_Script: {fileID: 11500000, guid: 1044986b35e39234b8bc84db5118e1b4, type: 3}
  m_Name: 1_Q10_Minggu
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  mainQuestion: Malam minggu tiba. Biasanya jam segini kalian selalu janjian untuk
    makan bareng keluar karena hari ini adalah hari libur dan waktunya untuk bersenang-senang.
  choices:
  - choiceText: 'Aku akan tetap dandan dan menunggu. Siapa tahu dia memberi kejutan
      datang.

'
    systemResponse: Kamu berdiri di depan cermin, bersiap untuk kencan yang hanya
      ada di kepalamu.
    addDistress: 0
    addDenial: 10
    addRumination: 0
    addHope: 15
    category: 0
  - choiceText: 'Aku akan pergi nongkrong bersama temanku yang lainnya.

'
    systemResponse: Kamu mengisi jadwalmu sepadat mungkin agar tidak ada celah untuk
      merindukannya.
    addDistress: 0
    addDenial: 5
    addRumination: 10
    addHope: 0
    category: 0
  - choiceText: 'Aku akan diam di kamar. Malam ini terasa salah dan sepi.

'
    systemResponse: Keheningan di kamar itu menjeritkan namanya.
    addDistress: 15
    addDenial: 0
    addRumination: 0
    addHope: -10
    category: 0
